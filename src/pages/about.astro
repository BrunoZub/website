---
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About | Bruno Zub" description="About Bruno Zub">
	<div class="stack gap-20">
		<main class="wrapper about">
			<Hero
				title="About"
				tagline="Thanks for stopping by. Read below to learn more about myself and my background."
			>
				<img
					width="1553"
					height="873"
					src="/assets/at-work.jpg"
					alt="Bruno Zub"
				/>
			</Hero>

			<section>
				<h2 class="section-title">Background</h2>
				<div class="content">
					<p>
						Hello, I'm Bruno Zub — a tinkerer, problem-solver, and tech enthusiast making my way into IT after a few scenic detours.
					</p>
					<p>
						My path into IT wasn't exactly straight. I went to college for civil engineering, where I learned to break down complex problems and developed a solid base in analytical thinking. I then moved to London and embarked on a creative career in video editing. That role taught me adaptability, how to juggle deadlines, and the art of communicating with clients effectively.
					</p>
					<p>
						Now, I'm bringing all that chaos-tested experience into IT, where problem-solving finally feels like home. I've spent the last two years deep-diving into homelab infrastructure, virtualization, and network security.
					</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">Education</h2>
				<div class="content">
					<p>Civil Engineering (Partial)</p>
					<p>Self-Taught IT & Systems Administration</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">Skills</h2>
				<div class="content">
					<p>Virtualization (Proxmox VE), Containers (Docker, LXC), Linux Administration (Debian/Ubuntu), Windows Server, Active Directory, ZFS, Networking (Tailscale, Nginx, Cloudflare Tunnels), Scripting (Python).</p>
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.about {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
	}

	img {
		margin-top: 1.5rem;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	section {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		color: var(--gray-200);
	}

	.section-title {
		grid-column-start: 1;
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	.content {
		grid-column: 2 / 4;
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.about {
			display: grid;
			grid-template-columns: 1fr 60% 1fr;
		}

		.about > :global(:first-child) {
			grid-column-start: 2;
		}

		section {
			display: contents;
			font-size: var(--text-lg);
		}
	}
</style>
